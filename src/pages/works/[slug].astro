---
import MarkdownPageLayout from "../../layouts/MarkdownPageLayout.astro";
import { getDb, getWorkBySlug } from "../../lib/db";
import { renderMarkdown } from "../../lib/markdown";

const slug = Astro.params.slug || "";
const work = await getWorkBySlug(getDb(Astro.locals), slug);
if (!work) {
  Astro.response.status = 404;
}
---

{
  work ? (
    <MarkdownPageLayout
      title={work.title}
      description={work.summary}
      date={work.publishedAt}
      tags={work.tags}
    >
      <Fragment set:html={renderMarkdown(work.body)} />
    </MarkdownPageLayout>
  ) : (
    <MarkdownPageLayout title="作品が見つかりません" description="Not Found">
      <p>指定された作品は存在しないか、まだ公開されていません。</p>
    </MarkdownPageLayout>
  )
}
