---
import BaseLayout from "../layouts/BaseLayout.astro";
import DadsButton from "../components/DadsButton.astro";
import SectionHeading from "../components/SectionHeading.astro";
import NoticeBanner from "../components/NoticeBanner.astro";

const status = Astro.url.searchParams.get("status");
const notices = {
  ok: {
    tone: "success",
    text: "送信を受け付けました。内容を確認して返信します。"
  },
  missing: {
    tone: "error",
    text: "未入力の必須項目があります。入力内容を確認してください。"
  },
  email: {
    tone: "error",
    text: "メールアドレスの形式が正しくありません。"
  },
  error: {
    tone: "error",
    text: "送信に失敗しました。時間をおいて再度お試しください。"
  }
} as const;
const notice = status ? notices[status as keyof typeof notices] : undefined;
---

<BaseLayout title="お問い合わせ" description="お問い合わせフォーム">
  <section class="page-section">
    <SectionHeading
      eyebrow="Contact"
      title="お問い合わせ"
      intro="相談内容を送っていただければ、確認後に返信します。"
    />
    {
      notice && (
        <NoticeBanner tone={notice.tone === "success" ? "success" : "error"} text={notice.text} />
      )
    }
    <form class="contact-form stack" method="post" action="/api/contact">
      <div class="dads-form-control-label app-field" data-size="md">
        <label class="dads-form-control-label__label" for="name">お名前<span class="dads-form-control-label__requirement" data-required="true">※必須</span></label>
        <span class="dads-input-text">
          <input class="dads-input-text__input" data-size="md" id="name" name="name" autocomplete="name" required />
        </span>
      </div>
      <div class="dads-form-control-label app-field" data-size="md">
        <label class="dads-form-control-label__label" for="email">メールアドレス<span class="dads-form-control-label__requirement" data-required="true">※必須</span></label>
        <span class="dads-input-text">
          <input
            class="dads-input-text__input"
            data-size="md"
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          inputmode="email"
          required
        />
        </span>
      </div>
      <div class="field honeyfield">
        <label for="company">会社名</label>
        <input
          id="company"
          name="company"
          tabindex="-1"
          autocomplete="organization"
        />
      </div>
      <div class="dads-form-control-label app-field" data-size="md">
        <label class="dads-form-control-label__label" for="message">内容<span class="dads-form-control-label__requirement" data-required="true">※必須</span></label>
        <p class="dads-form-control-label__support-text">相談内容や依頼内容をそのまま入力してください。</p>
        <span class="dads-textarea">
          <textarea class="dads-textarea__textarea" id="message" name="message" rows="8" required></textarea>
        </span>
      </div>
      <DadsButton type="submit" label="送信する" />
      <p class="form-note">
        送信先は Cloudflare Worker 上の API です。返信先のメールアドレスを確認してから送信してください。
      </p>
    </form>
  </section>
</BaseLayout>
