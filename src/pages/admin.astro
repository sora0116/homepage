---
import BaseLayout from "../layouts/BaseLayout.astro";
import DadsButton from "../components/DadsButton.astro";
import NoticeBanner from "../components/NoticeBanner.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { isLocalAdminLoginEnabled } from "../lib/admin-auth";
import { getAdminPageData } from "../lib/admin-page";

const { session, db, status, error, posts, works, inquiries } = await getAdminPageData(Astro);
const usesLocalAdminLogin = isLocalAdminLoginEnabled(Astro.locals);
---

<BaseLayout title="Admin" description="Content management">
  <section class="page-section">
    <SectionHeading
      eyebrow="Admin"
      title="コンテンツ管理"
      intro="編集画面への導線と、現在の公開状況をまとめて確認します。"
    />

    {!db && (
      <NoticeBanner tone="error" text="D1 binding `DB` が見つかりません。Cloudflare Worker の Variables and Bindings に D1 を追加してください。" />
    )}

    {status && (
      <NoticeBanner tone="success" text="更新を反映しました。" />
    )}

    {error && (
      <NoticeBanner
        tone="error"
        text={
          error === "unauthorized"
            ? "ログインが必要です。"
            : error === "forbidden"
              ? "この GitHub アカウントには管理権限がありません。"
              : error === "post_slug"
                ? "記事 slug が重複しています。"
                : error === "work_slug"
                  ? "作品 slug が重複しています。"
                  : "入力内容を確認してください。"
        }
      />
    )}

    {!session ? (
      <div class="admin-shell stack">
        <p>
          {usesLocalAdminLogin
            ? "ローカル開発モードの簡易ログインで管理画面へ入ります。D1 更新や本文編集を localhost 上で確認できます。"
            : "GitHub OAuth で管理画面へログインします。認証後はこのページへ戻り、更新操作ができます。"}
        </p>
        <div class="button-row">
          <DadsButton
            href="/api/admin/auth/login"
            label={usesLocalAdminLogin ? "ローカル管理者でログイン" : "GitHub でログイン"}
          />
        </div>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="admin-topbar">
          <div>
            <p class="eyebrow">Signed in</p>
            <p><strong>{session.name || session.login}</strong></p>
            <p class="meta">@{session.login}</p>
          </div>
          <div class="button-row">
            <DadsButton href="/api/admin/auth/logout" tone="outline" label="ログアウト" />
          </div>
        </div>

        <div class="admin-grid">
          <article class="admin-card stack">
            <p class="eyebrow">Posts</p>
            <h2 class="dads-heading" data-size="24">記事管理</h2>
            <p>記事の作成、公開切替、更新、削除を行います。</p>
            <p class="meta">
              全 {posts.length} 件 / 公開 {posts.filter((post) => post.status === "published").length} 件
            </p>
            <div class="button-row">
              <DadsButton href="/admin/posts" label="記事を管理" />
            </div>
          </article>

          <article class="admin-card stack">
            <p class="eyebrow">Works</p>
            <h2 class="dads-heading" data-size="24">作品管理</h2>
            <p>作品一覧とトップの featured 表示を管理します。</p>
            <p class="meta">
              全 {works.length} 件 / featured {works.filter((work) => work.featured).length} 件
            </p>
            <div class="button-row">
              <DadsButton href="/admin/works" label="作品を管理" />
            </div>
          </article>

          <article class="admin-card stack">
            <p class="eyebrow">Homepage</p>
            <h2 class="dads-heading" data-size="24">トップページ設定</h2>
            <p>ヒーロー文言、自己紹介、連絡導線などの設定を更新します。</p>
            <div class="button-row">
              <DadsButton href="/admin/homepage" label="設定を編集" />
            </div>
          </article>

          <article class="admin-card stack">
            <p class="eyebrow">Inquiries</p>
            <h2 class="dads-heading" data-size="24">お問い合わせ管理</h2>
            <p>受信した問い合わせ内容を確認し、対応状況を切り替えます。</p>
            <p class="meta">
              全 {inquiries.length} 件 / 未対応 {inquiries.filter((inquiry) => inquiry.status === "new").length} 件
            </p>
            <div class="button-row">
              <DadsButton href="/admin/inquiries" label="お問い合わせを見る" />
            </div>
          </article>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
