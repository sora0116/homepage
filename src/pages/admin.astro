---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getAdminPageData } from "../lib/admin-page";

const { session, db, status, error, posts, works } = await getAdminPageData(Astro);
---

<BaseLayout title="Admin" description="Content management">
  <section class="page-section">
    <SectionHeading
      eyebrow="Admin"
      title="コンテンツ管理"
      intro="編集画面への導線と、現在の公開状況をまとめて確認します。"
    />

    {!db && (
      <p class="notice notice--error" role="alert">
        D1 binding `DB` が見つかりません。Cloudflare Worker の Variables and
        Bindings に D1 を追加してください。
      </p>
    )}

    {status && (
      <p class="notice notice--success" role="status">
        更新を反映しました。
      </p>
    )}

    {error && (
      <p class="notice notice--error" role="alert">
        {error === "unauthorized" && "ログインが必要です。"}
        {error === "forbidden" && "この GitHub アカウントには管理権限がありません。"}
        {error === "post_slug" && "記事 slug が重複しています。"}
        {error === "work_slug" && "作品 slug が重複しています。"}
        {error === "invalid" && "入力内容を確認してください。"}
      </p>
    )}

    {!session ? (
      <div class="admin-shell stack">
        <p>
          GitHub OAuth で管理画面へログインします。認証後はこのページへ戻り、更新操作ができます。
        </p>
        <div class="button-row">
          <a class="button" href="/api/admin/auth/login">
            GitHub でログイン
          </a>
        </div>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="admin-topbar">
          <div>
            <p class="eyebrow">Signed in</p>
            <p><strong>{session.name || session.login}</strong></p>
            <p class="meta">@{session.login}</p>
          </div>
          <div class="button-row">
            <a class="button button--secondary" href="/api/admin/auth/logout">
              ログアウト
            </a>
          </div>
        </div>

        <div class="admin-grid">
          <article class="admin-card stack">
            <p class="eyebrow">Posts</p>
            <h2>記事管理</h2>
            <p>記事の作成、公開切替、更新、削除を行います。</p>
            <p class="meta">
              全 {posts.length} 件 / 公開 {posts.filter((post) => post.status === "published").length} 件
            </p>
            <div class="button-row">
              <a class="button" href="/admin/posts">記事を管理</a>
            </div>
          </article>

          <article class="admin-card stack">
            <p class="eyebrow">Works</p>
            <h2>作品管理</h2>
            <p>作品一覧とトップの featured 表示を管理します。</p>
            <p class="meta">
              全 {works.length} 件 / featured {works.filter((work) => work.featured).length} 件
            </p>
            <div class="button-row">
              <a class="button" href="/admin/works">作品を管理</a>
            </div>
          </article>

          <article class="admin-card stack">
            <p class="eyebrow">Homepage</p>
            <h2>トップページ設定</h2>
            <p>ヒーロー文言、自己紹介、連絡導線などの設定を更新します。</p>
            <div class="button-row">
              <a class="button" href="/admin/homepage">設定を編集</a>
            </div>
          </article>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
