---
import MarkdownPageLayout from "../../layouts/MarkdownPageLayout.astro";
import { hasCloudflareAccess } from "../../lib/cloudflare-access";
import { getDb, getPostBySlug } from "../../lib/db";
import { renderMarkdown } from "../../lib/markdown";

const slug = Astro.params.slug || "";
const hasAccess = hasCloudflareAccess(Astro.request);
const post = hasAccess
  ? await getPostBySlug(getDb(Astro.locals), slug, { includePrivate: true })
  : null;

if (!post || post.visibility !== "private") {
  Astro.response.status = 404;
}
---

{
  post && post.visibility === "private" ? (
    <MarkdownPageLayout
      title={post.title}
      description={post.description}
      date={post.publishedAt}
      tags={post.tags}
      breadcrumbs={[
        { href: "/", label: "ホーム" },
        { href: "/private-blog/", label: "限定ブログ" },
        { label: post.title }
      ]}
    >
      <Fragment set:html={renderMarkdown(post.body)} />
    </MarkdownPageLayout>
  ) : (
    <MarkdownPageLayout
      title="記事が見つかりません"
      description="Not Found"
      breadcrumbs={[
        { href: "/", label: "ホーム" },
        { href: "/private-blog/", label: "限定ブログ" },
        { label: "Not Found" }
      ]}
    >
      <p>指定された記事は存在しないか、Cloudflare Access 経由ではありません。</p>
    </MarkdownPageLayout>
  )
}
