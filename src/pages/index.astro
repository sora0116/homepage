---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PostCard from "../components/PostCard.astro";
import WorkCard from "../components/WorkCard.astro";
import { getDb, getHomepageSettings, listPosts, listWorks } from "../lib/db";
import { siteMeta } from "../lib/site";

const db = getDb(Astro.locals);
const posts = (await listPosts(db)).slice(0, 3);
const works = await listWorks(db);
const featuredWorks = works.filter((work) => work.featured).slice(0, 3);
const homepage = await getHomepageSettings(db);
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">{homepage.heroEyebrow}</p>
    <h1>{homepage.heroTitle}</h1>
    <p class="lead">{homepage.heroIntro}</p>
    <div class="button-row">
      <a class="button" href="/blog/">ブログを見る</a>
      <a class="button button--secondary" href="/contact/">問い合わせる</a>
    </div>
    <div class="hero-meta">
      <div>
        <dt>拠点</dt>
        <dd>{homepage.location}</dd>
      </div>
      <div>
        <dt>関心</dt>
        <dd>{homepage.interests}</dd>
      </div>
      <div>
        <dt>連絡先</dt>
        <dd><a href={`mailto:${homepage.email}`}>{homepage.email}</a></dd>
      </div>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="About"
      title="自己紹介"
      intro={homepage.aboutBody}
    />
    <div class="info-panel">
      <p>
        このサイトでは、制作物そのものと、その背景にある判断や試行錯誤を並べて記録します。
        単発のポートフォリオではなく、蓄積される公開ノートとして育てていく前提です。
      </p>
      <ul class="plain-list">
        {homepage.specialties.map((specialty) => <li>{specialty}</li>)}
      </ul>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Works"
      title="代表作品"
      intro="最近の制作物や継続的に育てている取り組みをまとめています。"
    />
    <div class="grid">
      {featuredWorks.map((work) => <WorkCard work={work} />)}
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Blog"
      title="最新記事"
      intro="設計判断、実装メモ、運用で気づいたことを記事として残しています。"
    />
    <div class="stack">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="page-section cta-panel">
    <SectionHeading
      eyebrow="Contact"
      title="相談や依頼について"
      intro={homepage.contactIntro}
    />
    <div class="button-row">
      <a class="button" href="/contact/">問い合わせフォームへ</a>
      <a class="button button--secondary" href={siteMeta.social[0].href}>
        GitHub
      </a>
    </div>
  </section>
</BaseLayout>
