---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import DadsButton from "../../../components/DadsButton.astro";
import NoticeBanner from "../../../components/NoticeBanner.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import AdminMarkdownField from "../../../components/AdminMarkdownField.astro";
import { getAdminPageData, toDateTimeLocal, toLinksInput, toTagsInput } from "../../../lib/admin-page";
import { getWorkById } from "../../../lib/db";

const { session, db, status, error } = await getAdminPageData(Astro);
const id = Astro.params.id || "";
const work = session ? await getWorkById(db, id) : null;
---

<BaseLayout title="Edit Work" description="Edit work">
  <section class="page-section">
    <SectionHeading eyebrow="Admin" title="作品編集" intro="選択した作品だけに集中して編集します。" />
    {!db && <NoticeBanner tone="error" text="D1 binding `DB` が見つかりません。" />}
    {status && <NoticeBanner tone="success" text="更新を反映しました。" />}
    {error && <NoticeBanner tone="error" text={error === "work_slug" ? "作品 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"} />}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <DadsButton href="/admin" label="/admin へ戻る" />
      </div>
    ) : !work ? (
      <div class="admin-shell stack">
        <p>指定した作品が見つかりません。</p>
        <DadsButton href="/admin/works" label="作品一覧へ戻る" />
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <DadsButton href="/admin/works" tone="outline" label="作品一覧へ戻る" />
          <DadsButton href={`/works/${work.slug}/`} tone="outline" label="公開ページ" />
        </div>
        <form class="admin-form stack" method="post" action="/api/admin/works">
          <input type="hidden" name="id" value={work.id} />
          <input type="hidden" name="returnTo" value={`/admin/works/${work.id}`} />
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="slug">slug</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="slug" name="slug" value={work.slug} required /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="title">タイトル</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="title" name="title" value={work.title} required /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="summary">概要</label>
            <span class="dads-textarea"><textarea class="dads-textarea__textarea" id="summary" name="summary" rows="3" required>{work.summary}</textarea></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="tags">タグ</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="tags" name="tags" value={toTagsInput(work.tags)} /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="links">リンク</label>
            <span class="dads-textarea"><textarea class="dads-textarea__textarea" id="links" name="links" rows="3">{toLinksInput(work.links)}</textarea></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="status">状態</label>
            <span class="dads-select"><span class="dads-select__control"><select class="dads-select__select" data-size="md" id="status" name="status"><option value="draft" selected={work.status === "draft"}>draft</option><option value="published" selected={work.status === "published"}>published</option></select><svg class="dads-select__chevron" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 17L3 8L4 7L12 15L20 7L21 8L12 17Z" fill="currentColor"></path></svg></span></span>
          </div>
          <div class="dads-form-control-label app-field checkbox-field" data-size="md">
            <label class="dads-form-control-label__label" for="featured">掲載設定</label>
            <label class="dads-checkbox" data-size="md">
              <span class="dads-checkbox__checkbox"><input class="dads-checkbox__input" id="featured" name="featured" type="checkbox" value="true" checked={work.featured} /></span>
              <span class="dads-checkbox__label">トップに表示</span>
            </label>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="publishedAt">公開日時</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="publishedAt" name="publishedAt" type="datetime-local" value={toDateTimeLocal(work.publishedAt)} required /></span>
          </div>
          <AdminMarkdownField
            id="body"
            name="body"
            label="本文"
            rows={12}
            value={work.body}
          />
          <div class="button-row">
            <DadsButton type="submit" name="_action" value="update" label="保存" />
            <DadsButton type="submit" tone="outline" name="_action" value="delete" label="削除" />
          </div>
        </form>
      </div>
    )}
  </section>
</BaseLayout>
