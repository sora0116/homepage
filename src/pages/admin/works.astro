---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getAdminPageData } from "../../lib/admin-page";
import { formatDateTime } from "../../lib/db";

const { session, db, status, error, works } = await getAdminPageData(Astro);
---

<BaseLayout title="Admin Works" description="Work management">
  <section class="page-section">
    <SectionHeading
      eyebrow="Admin"
      title="作品管理"
      intro="作品の一覧確認と個別編集画面への導線をまとめています。"
    />

    {!db && (
      <p class="notice notice--error" role="alert">
        D1 binding `DB` が見つかりません。Cloudflare Worker の Variables and Bindings に D1 を追加してください。
      </p>
    )}

    {status && <p class="notice notice--success" role="status">更新を反映しました。</p>}
    {error && <p class="notice notice--error" role="alert">{error === "work_slug" ? "作品 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"}</p>}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <div class="button-row">
          <a class="button" href="/admin">/admin へ戻る</a>
        </div>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <a class="button button--secondary" href="/admin">管理トップへ戻る</a>
          <a class="button" href="/admin/works/new">新規作品を作成</a>
        </div>

        <div class="admin-list">
          {works.map((work) => (
            <article class="admin-card stack">
              <div class="admin-inquiry-header">
                <div class="stack">
                  <h3>{work.title}</h3>
                  <p class="meta">
                    {work.slug} / {formatDateTime(work.publishedAt)}
                  </p>
                </div>
                <p class="meta">status: {work.status} / featured: {work.featured ? "yes" : "no"}</p>
              </div>
              <p>{work.summary}</p>
              <div class="button-row">
                <a class="button" href={`/admin/works/${work.id}`}>この作品を編集</a>
                <a class="button button--secondary" href={`/works/${work.slug}/`}>公開ページ</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
