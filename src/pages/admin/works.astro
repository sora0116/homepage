---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getAdminPageData, toDateTimeLocal, toLinksInput, toTagsInput } from "../../lib/admin-page";

const { session, db, status, error, works } = await getAdminPageData(Astro);
---

<BaseLayout title="Admin Works" description="Work management">
  <section class="page-section">
    <SectionHeading
      eyebrow="Admin"
      title="作品管理"
      intro="作品一覧、本文、featured 表示を管理します。"
    />

    {!db && (
      <p class="notice notice--error" role="alert">
        D1 binding `DB` が見つかりません。Cloudflare Worker の Variables and Bindings に D1 を追加してください。
      </p>
    )}

    {status && <p class="notice notice--success" role="status">更新を反映しました。</p>}
    {error && <p class="notice notice--error" role="alert">{error === "work_slug" ? "作品 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"}</p>}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <div class="button-row">
          <a class="button" href="/admin">/admin へ戻る</a>
        </div>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <a class="button button--secondary" href="/admin">管理トップへ戻る</a>
        </div>

        <form class="admin-form stack" method="post" action="/api/admin/works">
          <input type="hidden" name="_action" value="create" />
          <h3>新規作品</h3>
          <div class="field">
            <label for="work-create-slug">slug</label>
            <input id="work-create-slug" name="slug" required />
          </div>
          <div class="field">
            <label for="work-create-title">タイトル</label>
            <input id="work-create-title" name="title" required />
          </div>
          <div class="field">
            <label for="work-create-summary">概要</label>
            <textarea id="work-create-summary" name="summary" rows="3" required></textarea>
          </div>
          <div class="field">
            <label for="work-create-tags">タグ</label>
            <input id="work-create-tags" name="tags" placeholder="Astro, Cloudflare" />
          </div>
          <div class="field">
            <label for="work-create-links">リンク</label>
            <textarea id="work-create-links" name="links" rows="3" placeholder="GitHub|https://github.com/...\nDemo|https://..."></textarea>
          </div>
          <div class="field">
            <label for="work-create-status">状態</label>
            <select id="work-create-status" name="status">
              <option value="draft">draft</option>
              <option value="published">published</option>
            </select>
          </div>
          <div class="field checkbox-field">
            <label>
              <input id="work-create-featured" name="featured" type="checkbox" value="true" />
              トップ表示
            </label>
          </div>
          <div class="field">
            <label for="work-create-publishedAt">公開日時</label>
            <input id="work-create-publishedAt" name="publishedAt" type="datetime-local" value={toDateTimeLocal(new Date().toISOString())} required />
          </div>
          <div class="field">
            <label for="work-create-body">本文</label>
            <textarea id="work-create-body" name="body" rows="8" required></textarea>
          </div>
          <button class="button" type="submit">作品を作成</button>
        </form>

        <div class="admin-list">
          {works.map((work) => (
            <form class="admin-form stack" method="post" action="/api/admin/works">
              <input type="hidden" name="id" value={work.id} />
              <h3>{work.title}</h3>
              <div class="field">
                <label>slug</label>
                <input name="slug" value={work.slug} required />
              </div>
              <div class="field">
                <label>タイトル</label>
                <input name="title" value={work.title} required />
              </div>
              <div class="field">
                <label>概要</label>
                <textarea name="summary" rows="3" required>{work.summary}</textarea>
              </div>
              <div class="field">
                <label>タグ</label>
                <input name="tags" value={toTagsInput(work.tags)} />
              </div>
              <div class="field">
                <label>リンク</label>
                <textarea name="links" rows="3">{toLinksInput(work.links)}</textarea>
              </div>
              <div class="field">
                <label>状態</label>
                <select name="status">
                  <option value="draft" selected={work.status === "draft"}>draft</option>
                  <option value="published" selected={work.status === "published"}>published</option>
                </select>
              </div>
              <div class="field checkbox-field">
                <label>
                  <input name="featured" type="checkbox" value="true" checked={work.featured} />
                  トップに表示
                </label>
              </div>
              <div class="field">
                <label>公開日時</label>
                <input name="publishedAt" type="datetime-local" value={toDateTimeLocal(work.publishedAt)} required />
              </div>
              <div class="field">
                <label>本文</label>
                <textarea name="body" rows="8" required>{work.body}</textarea>
              </div>
              <div class="button-row">
                <button class="button" type="submit" name="_action" value="update">保存</button>
                <button class="button button--secondary" type="submit" name="_action" value="delete">削除</button>
              </div>
            </form>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
