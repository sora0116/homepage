---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DadsButton from "../../components/DadsButton.astro";
import NoticeBanner from "../../components/NoticeBanner.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getAdminPageData } from "../../lib/admin-page";
import { formatDateTime } from "../../lib/db";

const { session, db, status, error, works } = await getAdminPageData(Astro);
---

<BaseLayout title="Admin Works" description="Work management">
  <section class="page-section">
    <SectionHeading
      eyebrow="Admin"
      title="作品管理"
      intro="作品の一覧確認と個別編集画面への導線をまとめています。"
    />

    {!db && (
      <NoticeBanner tone="error" text="D1 binding `DB` が見つかりません。Cloudflare Worker の Variables and Bindings に D1 を追加してください。" />
    )}

    {status && <NoticeBanner tone="success" text="更新を反映しました。" />}
    {error && <NoticeBanner tone="error" text={error === "work_slug" ? "作品 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"} />}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <div class="button-row">
          <DadsButton href="/admin" label="/admin へ戻る" />
        </div>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <DadsButton href="/admin" tone="outline" label="管理トップへ戻る" />
          <DadsButton href="/admin/works/new" label="新規作品を作成" />
        </div>

        <div class="admin-list">
          {works.map((work) => (
            <article class="admin-card stack">
              <div class="admin-inquiry-header">
                <div class="stack">
                  <h3 class="dads-heading" data-size="20">{work.title}</h3>
                  <p class="meta">
                    {work.slug} / {formatDateTime(work.publishedAt)}
                  </p>
                </div>
                <p class="meta">status: {work.status} / featured: {work.featured ? "yes" : "no"}</p>
              </div>
              <p>{work.summary}</p>
              <div class="button-row">
                <DadsButton href={`/admin/works/${work.id}`} label="この作品を編集" />
                <DadsButton href={`/works/${work.slug}/`} tone="outline" label="公開ページ" />
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
