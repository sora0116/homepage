---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import DadsButton from "../../../components/DadsButton.astro";
import NoticeBanner from "../../../components/NoticeBanner.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import AdminMarkdownField from "../../../components/AdminMarkdownField.astro";
import { getAdminPageData, toDateTimeLocal, toTagsInput } from "../../../lib/admin-page";
import { getPostById } from "../../../lib/db";

const { session, db, status, error } = await getAdminPageData(Astro);
const id = Astro.params.id || "";
const post = session ? await getPostById(db, id) : null;
const postHref =
  post && post.visibility === "private" ? `/private-blog/${post.slug}/` : post ? `/blog/${post.slug}/` : "/blog/";
---

<BaseLayout title="Edit Post" description="Edit post">
  <section class="page-section">
    <SectionHeading eyebrow="Admin" title="記事編集" intro="選択した記事だけに集中して編集します。" />
    {!db && <NoticeBanner tone="error" text="D1 binding `DB` が見つかりません。" />}
    {status && <NoticeBanner tone="success" text="更新を反映しました。" />}
    {error && <NoticeBanner tone="error" text={error === "post_slug" ? "記事 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"} />}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <DadsButton href="/admin" label="/admin へ戻る" />
      </div>
    ) : !post ? (
      <div class="admin-shell stack">
        <p>指定した記事が見つかりません。</p>
        <DadsButton href="/admin/posts" label="記事一覧へ戻る" />
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <DadsButton href="/admin/posts" tone="outline" label="記事一覧へ戻る" />
          <DadsButton href={postHref} tone="outline" label="公開ページ" />
        </div>
        <form class="admin-form stack" method="post" action="/api/admin/posts">
          <input type="hidden" name="id" value={post.id} />
          <input type="hidden" name="returnTo" value={`/admin/posts/${post.id}`} />
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="slug">slug</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="slug" name="slug" value={post.slug} required /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="title">タイトル</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="title" name="title" value={post.title} required /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="description">概要</label>
            <span class="dads-textarea"><textarea class="dads-textarea__textarea" id="description" name="description" rows="3" required>{post.description}</textarea></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="tags">タグ</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="tags" name="tags" value={toTagsInput(post.tags)} /></span>
          </div>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="status">状態</label>
            <span class="dads-select"><span class="dads-select__control"><select class="dads-select__select" data-size="md" id="status" name="status"><option value="draft" selected={post.status === "draft"}>draft</option><option value="published" selected={post.status === "published"}>published</option></select><svg class="dads-select__chevron" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 17L3 8L4 7L12 15L20 7L21 8L12 17Z" fill="currentColor"></path></svg></span></span>
          </div>
          <label class="dads-checkbox app-field">
            <span class="dads-checkbox__checkbox">
              <input
                class="dads-checkbox__input"
                type="checkbox"
                name="isPrivate"
                value="true"
                checked={post.visibility === "private"}
              />
            </span>
            <span class="dads-checkbox__label">
              Cloudflare Access 経由だけで見せる
            </span>
          </label>
          <div class="dads-form-control-label app-field" data-size="md">
            <label class="dads-form-control-label__label" for="publishedAt">公開日時</label>
            <span class="dads-input-text"><input class="dads-input-text__input" data-size="md" id="publishedAt" name="publishedAt" type="datetime-local" value={toDateTimeLocal(post.publishedAt)} required /></span>
          </div>
          <AdminMarkdownField
            id="body"
            name="body"
            label="本文"
            rows={12}
            value={post.body}
          />
          <div class="button-row">
            <DadsButton type="submit" name="_action" value="update" label="保存" />
            <DadsButton type="submit" tone="outline" name="_action" value="delete" label="削除" />
          </div>
        </form>
      </div>
    )}
  </section>
</BaseLayout>
