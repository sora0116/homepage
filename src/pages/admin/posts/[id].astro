---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import { getAdminPageData, toDateTimeLocal, toTagsInput } from "../../../lib/admin-page";
import { getPostById } from "../../../lib/db";

const { session, db, status, error } = await getAdminPageData(Astro);
const id = Astro.params.id || "";
const post = session ? await getPostById(db, id) : null;
---

<BaseLayout title="Edit Post" description="Edit post">
  <section class="page-section">
    <SectionHeading eyebrow="Admin" title="記事編集" intro="選択した記事だけに集中して編集します。" />
    {!db && <p class="notice notice--error" role="alert">D1 binding `DB` が見つかりません。</p>}
    {status && <p class="notice notice--success" role="status">更新を反映しました。</p>}
    {error && <p class="notice notice--error" role="alert">{error === "post_slug" ? "記事 slug が重複しています。" : error === "invalid" ? "入力内容を確認してください。" : "ログインが必要です。"}</p>}

    {!session ? (
      <div class="admin-shell stack">
        <p>先に管理画面へログインしてください。</p>
        <a class="button" href="/admin">/admin へ戻る</a>
      </div>
    ) : !post ? (
      <div class="admin-shell stack">
        <p>指定した記事が見つかりません。</p>
        <a class="button" href="/admin/posts">記事一覧へ戻る</a>
      </div>
    ) : (
      <div class="admin-shell stack">
        <div class="button-row">
          <a class="button button--secondary" href="/admin/posts">記事一覧へ戻る</a>
          <a class="button button--secondary" href={`/blog/${post.slug}/`}>公開ページ</a>
        </div>
        <form class="admin-form stack" method="post" action="/api/admin/posts">
          <input type="hidden" name="id" value={post.id} />
          <input type="hidden" name="returnTo" value={`/admin/posts/${post.id}`} />
          <div class="field">
            <label for="slug">slug</label>
            <input id="slug" name="slug" value={post.slug} required />
          </div>
          <div class="field">
            <label for="title">タイトル</label>
            <input id="title" name="title" value={post.title} required />
          </div>
          <div class="field">
            <label for="description">概要</label>
            <textarea id="description" name="description" rows="3" required>{post.description}</textarea>
          </div>
          <div class="field">
            <label for="tags">タグ</label>
            <input id="tags" name="tags" value={toTagsInput(post.tags)} />
          </div>
          <div class="field">
            <label for="status">状態</label>
            <select id="status" name="status">
              <option value="draft" selected={post.status === "draft"}>draft</option>
              <option value="published" selected={post.status === "published"}>published</option>
            </select>
          </div>
          <div class="field">
            <label for="publishedAt">公開日時</label>
            <input id="publishedAt" name="publishedAt" type="datetime-local" value={toDateTimeLocal(post.publishedAt)} required />
          </div>
          <div class="field">
            <label for="body">本文</label>
            <textarea id="body" name="body" rows="10" required>{post.body}</textarea>
          </div>
          <div class="button-row">
            <button class="button" type="submit" name="_action" value="update">保存</button>
            <button class="button button--secondary" type="submit" name="_action" value="delete">削除</button>
          </div>
        </form>
      </div>
    )}
  </section>
</BaseLayout>
