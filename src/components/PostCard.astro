---
import { formatDate } from "../lib/content";

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      date: Date;
      tags: string[];
    };
  };
}

const { post } = Astro.props;
---

<article class="card">
  <p class="meta">{formatDate(post.data.date)}</p>
  <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <ul class="tag-list" aria-label="タグ">
    {post.data.tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>
