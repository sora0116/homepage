---
import DadsExampleFrame from "./DadsExampleFrame.astro";

interface Props {
  example?: string;
  height?: string;
  title?: string;
}

const { example = "border-on-row-and-column", height, title } = Astro.props;
---

<DadsExampleFrame
  component="table"
  example={example}
  height={height}
  title={title}
/>
