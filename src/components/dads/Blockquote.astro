---
import DadsExampleFrame from "./DadsExampleFrame.astro";

interface Props {
  example?: string;
  height?: string;
  title?: string;
}

const { example = "multiple-paragraphs", height, title } = Astro.props;
---

<DadsExampleFrame
  component="blockquote"
  example={example}
  height={height}
  title={title}
/>
