---
import DadsExampleFrame from "./DadsExampleFrame.astro";

interface Props {
  example?: string;
  height?: string;
  title?: string;
}

const { example = "desktop-and-mobile", height, title } = Astro.props;
---

<DadsExampleFrame
  component="hamburger-menu-button"
  example={example}
  height={height}
  title={title}
/>
