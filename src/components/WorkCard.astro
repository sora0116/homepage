---
import { formatDate } from "../lib/content";

interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  work: {
    slug: string;
    body: string;
    data: {
      title: string;
      summary: string;
      publishedAt: Date;
      tags: string[];
      links: LinkItem[];
      featured: boolean;
    };
  };
}

const { work } = Astro.props;
---

<article class="card">
  <p class="meta">{formatDate(work.data.publishedAt)}</p>
  <h3><a href={`/works/${work.slug}/`}>{work.data.title}</a></h3>
  <p>{work.data.summary}</p>
  <ul class="tag-list" aria-label="タグ">
    {work.data.tags.map((tag) => <li>{tag}</li>)}
  </ul>
  <div class="card-links">
    {work.data.links.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
</article>
