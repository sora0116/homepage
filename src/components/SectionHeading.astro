---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<div class="section-heading">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="dads-heading" data-size="32" data-chip>{title}</h2>
  {intro && <p class="section-intro">{intro}</p>}
</div>
