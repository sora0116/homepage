---
import { siteMeta } from "../lib/site";
---

<footer class="site-footer">
  <div class="container stack">
    <p class="eyebrow">連絡先</p>
    <ul class="footer-links">
      {
        siteMeta.social.map((item) => (
          <li><a class="dads-utility-link" href={item.href}><span class="dads-utility-link__label">{item.label}</span></a></li>
        ))
      }
    </ul>
    <p class="footer-note">© {new Date().getFullYear()} {siteMeta.author}</p>
  </div>
</footer>
