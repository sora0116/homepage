---
type ButtonTone = "solid-fill" | "outline" | "text";

interface Props {
  href?: string;
  label?: string;
  tone?: ButtonTone;
  type?: "button" | "submit" | "reset";
  className?: string;
  disabled?: boolean;
  name?: string;
  value?: string;
  target?: string;
  rel?: string;
  ariaLabel?: string;
}

const {
  href,
  label,
  tone = "solid-fill",
  type = "button",
  className,
  disabled = false,
  name,
  value,
  target,
  rel,
  ariaLabel
} = Astro.props;
---

{
  href ? (
    <a
      class:list={["dads-button", className]}
      data-size="md"
      data-type={tone}
      href={href}
      target={target}
      rel={rel}
      aria-label={ariaLabel}
    >
      <slot>{label}</slot>
    </a>
  ) : (
    <button
      class:list={["dads-button", className]}
      data-size="md"
      data-type={tone}
      type={type}
      disabled={disabled}
      name={name}
      value={value}
      aria-label={ariaLabel}
    >
      <slot>{label}</slot>
    </button>
  )
}
